"""Build-time dependency versions and provenance (generated by CMake — do not edit).

Only ``VTK_VERSION`` is enforced at import time (see ``pysmesh.__init__``): pySMESH's
``_core`` links VTK dynamically against the host environment's VTK, so a version mismatch
is an ABI hazard and must fail loudly. ``OCCT_VERSION`` / ``BOOST_VERSION`` are recorded
for provenance and debugging only.
"""

from __future__ import annotations

from typing import Final

VTK_VERSION: Final[str] = "@PYSMESH_VTK_VERSION@"
OCCT_VERSION: Final[str] = "@PYSMESH_OCCT_VERSION@"
BOOST_VERSION: Final[str] = "@PYSMESH_BOOST_VERSION@"
GIT_SHA: Final[str] = "@PYSMESH_GIT_SHA@"
BUILD_DATE: Final[str] = "@PYSMESH_BUILD_DATE@"
WITH_NETGEN: Final[bool] = @PYSMESH_WITH_NETGEN@
